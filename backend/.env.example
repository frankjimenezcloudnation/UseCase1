PROJECT_NAME="WTP Pension Prototyping Engine — Use Case 1"
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Anthropic Claude — used by Use Case 1 for the entitlement audit.
# The key is read from ANTHROPIC_API_KEY, or from the ATP alias (both accepted).
# Without a key the /analysis/compare endpoint returns a grounded demo report.
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-opus-4-8

# Per-document character cap fed to the model (keeps latency/cost bounded).
MAX_DOC_CHARS=60000

# Directory holding the fund + benchmark source documents.
# Defaults to the UseCase1/ project root (where the PDFs/docx/xlsx live).
# DOCUMENTS_DIR=/absolute/path/to/documents
